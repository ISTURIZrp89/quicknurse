# QuickNurse Configuration
# Copia este archivo a .env y ajusta los valores

# App
APP_NAME=QuickNurse
APP_VERSION=1.0.0
DEBUG=true
ENVIRONMENT=development

# Database
QUICKNURSE_DB_URL=sqlite:///./quicknurse.db

# Security (CAMBIA EN PRODUCCIÓN)
SECRET_KEY=tu-clave-secreta-muy-larga-y-segura-cambia-esto
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Ollama
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_TRIAGE_MODEL=phi4-mini:latest

# CORS (separar por comas en producción)
ALLOWED_ORIGINS=*

# Logging
LOG_LEVEL=INFO