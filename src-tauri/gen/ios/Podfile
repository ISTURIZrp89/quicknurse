# QuickNurse iOS Podfile

platform :ios, '15.0'
use_frameworks!

target 'QuickNurse' do
  # Tauri runtime
  pod 'Tauri', :path => '../../node_modules/@tauri-apps/api'
  pod 'TauriRuntime', :path => '../../node_modules/@tauri-apps/api/tauri-runtime'

  # SQLCipher for encrypted database
  pod 'SQLCipher', '~> 4.6.1'

  # Biometrics
  pod 'BiometricAuth', '~> 1.0'

  # Network
  pod 'Alamofire', '~> 5.8'

  # Keychain
  pod 'KeychainAccess', '~> 4.2'

  # Notifications
  pod 'OneSignal', '~> 5.0'
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    target.build_configurations.each do |config|
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '15.0'
      config.build_settings['ENABLE_BITCODE'] = 'NO'
      config.build_settings['SWIFT_VERSION'] = '5.9'
    end
  end
end